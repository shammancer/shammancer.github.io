---
title: Index
---

<% cards_html = capture_html do %>
  <% data.index.each do |item| %>
    <%= partial "partial/card", locals: {
      colour:  item["colour"],
      icon:    item["icon"],
      title:   item["title"],
      link:    item["link"],
      content: item["description"]
    } %>
  <% end %>
<% end %>

<%= partial "partial/card_grid", locals: { content: cards_html, columns: 2 } %>
