<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta name="viewport"
          content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <!-- Use the title from a pages frontmatter if it has one -->
    <title>Deuterium | <%= current_page.data.title || "" %></title>
    <%= stylesheet_link_tag "normalize" %>
    <%= stylesheet_link_tag "main" %>
    <link rel="preload" as="font" type="font/ttf" href="/fonts/Orbitron/Orbitron-Black.ttf" crossorigin>
    <link rel="preload" as="font" type="font/ttf" href="/fonts/Orbitron/Orbitron-Bold.ttf" crossorigin>
    <link rel="preload" as="font" type="font/ttf" href="/fonts/Rajdhani/Rajdhani-Regular.ttf" crossorigin>
    <link rel="preload" as="font" type="font/ttf" href="/fonts/ShareTechMono/ShareTechMono-Regular.ttf" crossorigin>
    <%= javascript_include_tag "zepto.min", defer: true%>
    <%= javascript_include_tag "main", defer: true%>
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico?">
  </head>
  <body>
    <div id="container">
      <%= partial "partial/header" %>
      <main>
          <%= yield %>
      </main>
      <%= partial "partial/footer" %>
    </div>
  </body>
</html>
